# ============================================================================
# Trading-Pod Dashboard — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# These are used by Vite at BUILD TIME (prefixed with VITE_).

# WebSocket URL for the Event Stream Durable Object
VITE_WS_URL=wss://trading-pod-event-stream.<your-subdomain>.workers.dev/ws

# Dashboard authentication token (must match DASHBOARD_TOKEN secret on event-stream worker)
VITE_DASHBOARD_TOKEN=

# FC Worker URL (for pause/freeze controls)
VITE_FC_URL=https://trading-pod-fc.<your-subdomain>.workers.dev

# Internal service secret (must match INTERNAL_SERVICE_SECRET on all workers)
VITE_INTERNAL_SECRET=

# Google OAuth Client ID (from Google Cloud Console)
# Leave blank to disable auth (dashboard will be open)
VITE_GOOGLE_CLIENT_ID=

# Allowed email addresses (comma-separated)
# Only these emails can log in. Leave blank to allow any Google account.
VITE_ALLOWED_EMAILS=
