# ============================================================================
# Trading-Pod — Root Environment Variables
# ============================================================================
# Copy to .env and fill in values.
# Worker secrets should be set via `wrangler secret put <NAME>` instead.

# ---- Cloudflare D1 ----
# Replace placeholder IDs in each worker's wrangler.jsonc after creating:
#   wrangler d1 create trading-pod-db
# D1_DATABASE_ID=

# ---- Cloudflare KV ----
# Create namespace and replace placeholder IDs:
#   wrangler kv namespace create CONFIG_KV
# KV_NAMESPACE_ID=

# ---- Worker Secrets (set via wrangler secret put) ----
# INTERNAL_SERVICE_SECRET — Shared token for service-to-service auth
# DASHBOARD_TOKEN         — Token for WebSocket auth from dashboard
# WEBHOOK_SECRET          — Shared secret for TradingView webhook validation
# IG_API_KEY              — IG REST API key
# IG_USERNAME             — IG username
# IG_PASSWORD             — IG password
# CAPITAL_API_KEY         — Capital.com API key
# CAPITAL_EMAIL           — Capital.com account email
# CAPITAL_PASSWORD        — Capital.com account password
# OANDA_API_TOKEN         — OANDA REST API bearer token
# OANDA_ACCOUNT_ID        — OANDA account ID

# ---- Trading Mode ----
# Set in wrangler.jsonc vars. "paper" = mock broker, "live" = real brokers.
# TRADING_MODE=paper
