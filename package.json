{
  "name": "trading-pod",
  "private": true,
  "version": "0.1.0",
  "description": "Fully automated, low-risk, multi-agent trading system",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "migrate": "node scripts/migrate-d1.mjs",
    "migrate:local": "node scripts/migrate-d1.mjs --local",
    "migrate:preview": "node scripts/migrate-d1.mjs --dry-run",
    "upgrade": "node scripts/upgrade.mjs",
    "upgrade:preview": "node scripts/upgrade.mjs --dry-run"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
